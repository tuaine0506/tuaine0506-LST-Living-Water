{
  "name": "living-water-wellness",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.mjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs --external:express --external:vite --external:ws --external:firebase-admin --external:firebase-admin/* --external:nodemailer",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "seed": "tsx seed.ts",
    "deploy": "npm run build && npx gh-pages -d dist"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.460.0",
    "motion": "^12.34.3",
    "nodemailer": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.7.0",
    "tsx": "^4.21.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
